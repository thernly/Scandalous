<Window x:Class="Scandalous.WPF.Views.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:materialDesign="http://materialdesigninxaml.net/winfx/xaml/themes"
        xmlns:viewModels="clr-namespace:Scandalous.WPF.ViewModels"
        xmlns:converters="clr-namespace:Scandalous.WPF.Converters"
        mc:Ignorable="d"
        Title="Scandalous - Document Scanner"
        Height="{Binding WindowHeight}"
        Width="{Binding WindowWidth}"
        Left="{Binding WindowLeft}"
        Top="{Binding WindowTop}"
        WindowState="{Binding WindowState}"
        MinHeight="600" MinWidth="900"
        WindowStartupLocation="Manual"
        TextElement.Foreground="{DynamicResource MaterialDesignBody}"
        TextElement.FontWeight="Regular"
        TextElement.FontSize="13"
        TextOptions.TextFormattingMode="Ideal"
        TextOptions.TextRenderingMode="Auto"
        Background="{DynamicResource MaterialDesignPaper}"
        FontFamily="{DynamicResource MaterialDesignFont}">
    <Window.Resources>
        <BooleanToVisibilityConverter x:Key="BooleanToVisibilityConverter"/>
        <converters:EnumToBooleanConverter x:Key="EnumToBooleanConverter"/>
    </Window.Resources>
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>
        <materialDesign:ColorZone Grid.Row="0" Mode="PrimaryMid" Padding="16" materialDesign:ElevationAssist.Elevation="Dp4">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>
                
                <StackPanel Grid.Column="0" Orientation="Horizontal">
                    <materialDesign:PackIcon Kind="Scanner" Width="32" Height="32" VerticalAlignment="Center" Margin="0,0,12,0"/>
                    <TextBlock Text="Scandalous" Style="{DynamicResource MaterialDesignHeadline5TextBlock}" VerticalAlignment="Center"/>
                    <TextBlock Text="Document Scanner" Style="{DynamicResource MaterialDesignBody1TextBlock}" VerticalAlignment="Center" Margin="8,0,0,0" Opacity="0.7"/>
                </StackPanel>
                
                <StackPanel Grid.Column="1" Orientation="Horizontal">
                    <ComboBox Style="{DynamicResource MaterialDesignOutlinedComboBox}"
                              ItemsSource="{Binding AvailableThemes}"
                              SelectedItem="{Binding SelectedTheme}"
                              materialDesign:HintAssist.Hint="Select Theme"
                              Width="120"
                              Margin="0,0,8,0"/>
                    <Button Style="{DynamicResource MaterialDesignIconButton}" 
                            ToolTip="Settings">
                        <materialDesign:PackIcon Kind="Cog"/>
                    </Button>
                    <Button Style="{DynamicResource MaterialDesignIconButton}" 
                            ToolTip="Reset Settings"
                            Command="{Binding ResetSettingsCommand}">
                        <materialDesign:PackIcon Kind="Restore"/>
                    </Button>
                </StackPanel>
            </Grid>
        </materialDesign:ColorZone>

        <!-- Main Content -->
        <Grid Grid.Row="1" Margin="16">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="{Binding LeftPanelWidth}" MinWidth="500" x:Name="LeftPanelColumn"/>
                <ColumnDefinition Width="8"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>

            <!-- Collapse/Expand Toggle Button -->
            <Button Grid.Column="0" Height="32" Width="32" Margin="0,0,0,8" VerticalAlignment="Top" HorizontalAlignment="Right"
                    Style="{DynamicResource MaterialDesignIconButton}"
                    ToolTip="Collapse/Expand Scan Controls"
                    Click="ToggleLeftPanel_Click">
                <materialDesign:PackIcon Kind="ChevronLeft" x:Name="CollapseIcon"/>
            </Button>

            <!-- Left Panel - Scan Controls -->
            <materialDesign:Card Grid.Column="0" Padding="16" materialDesign:ElevationAssist.Elevation="Dp2" MinWidth="500" x:Name="LeftPanelCard">
                <ScrollViewer VerticalScrollBarVisibility="Auto">
                    <StackPanel DataContext="{Binding ScanSettingsViewModel}">
                        <TextBlock Text="Scan Configuration" Style="{DynamicResource MaterialDesignHeadline6TextBlock}" Margin="0,0,0,16"/>
                        
                        <!-- Scanner Selection -->
                        <TextBlock Text="Scanner" Style="{DynamicResource MaterialDesignBody2TextBlock}" Margin="0,0,0,8"/>
                        <Grid Margin="0,0,0,16">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>
                            <ComboBox Grid.Column="0" Style="{DynamicResource MaterialDesignOutlinedComboBox}"
                                      ItemsSource="{Binding AvailableScanners}"
                                      SelectedItem="{Binding SelectedScanner}"
                                      materialDesign:HintAssist.Hint="Select Scanner"/>
                            <Button Grid.Column="1" 
                                    Style="{DynamicResource MaterialDesignIconButton}"
                                    Command="{Binding LoadAvailableScannersCommand}"
                                    Margin="8,0,0,0">
                                <materialDesign:PackIcon Kind="Refresh"/>
                            </Button>
                        </Grid>
                        <TextBlock Text="{Binding SelectedScannerStatus}" 
                                   Style="{DynamicResource MaterialDesignBody2TextBlock}" 
                                   Margin="0,-8,0,16" 
                                   Opacity="0.7"/>

                        <!-- Color Mode -->
                        <TextBlock Text="Color Mode" Style="{DynamicResource MaterialDesignBody2TextBlock}" Margin="0,0,0,8"/>
                        <StackPanel Orientation="Horizontal" Margin="0,0,0,16">
                            <StackPanel Orientation="Vertical" Margin="0,0,16,0">
                                <RadioButton Style="{DynamicResource MaterialDesignRadioButton}"
                                             Content="Color"
                                             IsChecked="{Binding SelectedColorMode, Converter={StaticResource EnumToBooleanConverter}, ConverterParameter=Color}"
                                             GroupName="ColorMode"/>
                                <Border BorderBrush="{DynamicResource MaterialDesignDivider}" BorderThickness="1" Margin="0,8,0,0">
                                    <Image Source="/Scandalous;component/Assets/color_preview.png" Width="80" Height="60" Stretch="UniformToFill"/>
                                </Border>
                            </StackPanel>
                            <StackPanel Orientation="Vertical" Margin="0,0,16,0">
                                <RadioButton Style="{DynamicResource MaterialDesignRadioButton}"
                                             Content="Grayscale"
                                             IsChecked="{Binding SelectedColorMode, Converter={StaticResource EnumToBooleanConverter}, ConverterParameter=Grayscale}"
                                             GroupName="ColorMode"/>
                                <Border BorderBrush="{DynamicResource MaterialDesignDivider}" BorderThickness="1" Margin="0,8,0,0">
                                    <Image Source="/Scandalous;component/Assets/grayscale_preview.png" Width="80" Height="60" Stretch="UniformToFill"/>
                                </Border>
                            </StackPanel>
                            <StackPanel Orientation="Vertical">
                                <RadioButton Style="{DynamicResource MaterialDesignRadioButton}"
                                             Content="Black &amp; White"
                                             IsChecked="{Binding SelectedColorMode, Converter={StaticResource EnumToBooleanConverter}, ConverterParameter=BlackAndWhite}"
                                             GroupName="ColorMode"/>
                                <Border BorderBrush="{DynamicResource MaterialDesignDivider}" BorderThickness="1" Margin="0,8,0,0">
                                    <Image Source="/Scandalous;component/Assets/blackwhite_preview.png" Width="80" Height="60" Stretch="UniformToFill"/>
                                </Border>
                            </StackPanel>
                        </StackPanel>
                        <TextBlock Text="{Binding SelectedColorModeDescription}" 
                                   Style="{DynamicResource MaterialDesignBody2TextBlock}" 
                                   Margin="0,0,0,16" 
                                   TextWrapping="Wrap"/>

                        <!-- Paper Source -->
                        <TextBlock Text="Paper Source" Style="{DynamicResource MaterialDesignBody2TextBlock}" Margin="0,0,0,8"/>
                        <StackPanel Orientation="Horizontal" Margin="0,0,0,16">
                            <RadioButton Style="{DynamicResource MaterialDesignRadioButton}"
                                         Content="Auto"
                                         IsChecked="{Binding SelectedPaperSource, Converter={StaticResource EnumToBooleanConverter}, ConverterParameter=Auto}"
                                         GroupName="PaperSource"/>
                            <RadioButton Style="{DynamicResource MaterialDesignRadioButton}"
                                         Content="Flatbed"
                                         IsChecked="{Binding SelectedPaperSource, Converter={StaticResource EnumToBooleanConverter}, ConverterParameter=Flatbed}"
                                         GroupName="PaperSource"
                                         Margin="16,0,0,0"/>
                            <RadioButton Style="{DynamicResource MaterialDesignRadioButton}"
                                         Content="Feeder (Duplex)"
                                         IsChecked="{Binding SelectedPaperSource, Converter={StaticResource EnumToBooleanConverter}, ConverterParameter=FeederDuplex}"
                                         GroupName="PaperSource"
                                         Margin="16,0,0,0"/>
                            <RadioButton Style="{DynamicResource MaterialDesignRadioButton}"
                                         Content="Feeder (Simplex)"
                                         IsChecked="{Binding SelectedPaperSource, Converter={StaticResource EnumToBooleanConverter}, ConverterParameter=FeederSimplex}"
                                         GroupName="PaperSource"
                                         Margin="16,0,0,0"/>
                        </StackPanel>

                        <!-- Resolution -->
                        <TextBlock Text="Resolution (DPI)" Style="{DynamicResource MaterialDesignBody2TextBlock}" Margin="0,0,0,8"/>
                        <Grid Margin="0,0,0,16">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>
                            <ComboBox Grid.Column="0"
                                      ItemsSource="{Binding Resolutions}"
                                      SelectedItem="{Binding SelectedResolution}"/>
                            <TextBox Grid.Column="1"
                                     Text="{Binding CustomResolution, UpdateSourceTrigger=PropertyChanged}"
                                     materialDesign:HintAssist.Hint="Custom DPI"
                                     materialDesign:HintAssist.HelperText="{Binding CustomResolutionError}"
                                     Width="100"
                                     Margin="8,0,0,0">
                                <TextBox.Style>
                                    <Style TargetType="TextBox" BasedOn="{StaticResource MaterialDesignOutlinedTextBox}">
                                        <Style.Triggers>
                                            <DataTrigger Binding="{Binding CustomResolutionError}" Value="Please enter a valid DPI (e.g., 300).">
                                                <Setter Property="materialDesign:HintAssist.Foreground" Value="{DynamicResource MaterialDesignValidationErrorBrush}"/>
                                            </DataTrigger>
                                        </Style.Triggers>
                                    </Style>
                                </TextBox.Style>
                            </TextBox>
                        </Grid>

                        <!-- Auto-Deskew and Blank Page Exclusion -->
                        <CheckBox Style="{DynamicResource MaterialDesignCheckBox}"
                                  Content="Auto-Deskew"
                                  IsChecked="{Binding AutoDeskew}"
                                  Margin="0,0,0,8"/>
                        <CheckBox Style="{DynamicResource MaterialDesignCheckBox}"
                                  Content="Exclude Blank Pages"
                                  IsChecked="{Binding ExcludeBlankPages}"
                                  Margin="0,0,0,16"/>

                        <!-- OCR Settings -->
                        <TextBlock Text="OCR Settings" Style="{DynamicResource MaterialDesignBody2TextBlock}" Margin="0,0,0,8"/>
                        <CheckBox Style="{DynamicResource MaterialDesignCheckBox}"
                                  Content="Enable OCR"
                                  IsChecked="{Binding OcrEnabled}"
                                  Margin="0,0,0,8"/>
                        <Grid Margin="0,0,0,16">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>
                            <TextBox Grid.Column="0" 
                                     Style="{DynamicResource MaterialDesignOutlinedTextBox}"
                                     Text="{Binding TessdataFolder, UpdateSourceTrigger=PropertyChanged}"
                                     materialDesign:HintAssist.Hint="Tessdata Folder"
                                     IsReadOnly="True"
                                     materialDesign:HintAssist.HelperText="{Binding TessdataFolderError}"/>
                            <Button Grid.Column="1" 
                                    Style="{DynamicResource MaterialDesignIconButton}"
                                    Command="{Binding SelectTessdataFolderCommand}"
                                    Margin="8,0,0,0">
                                <materialDesign:PackIcon Kind="FolderOpen"/>
                            </Button>
                        </Grid>

                        <!-- OCR Language -->
                        <TextBlock Text="OCR Language" Style="{DynamicResource MaterialDesignBody2TextBlock}" Margin="0,0,0,8"/>
                        <Grid Margin="0,0,0,16">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>
                            <ComboBox Grid.Column="0"
                                      Style="{DynamicResource MaterialDesignOutlinedComboBox}"
                                      ItemsSource="{Binding AvailableLanguages}"
                                      SelectedItem="{Binding SelectedLanguageCode}"
                                      materialDesign:HintAssist.Hint="Select Language"/>
                            <Button Grid.Column="1"
                                    Style="{DynamicResource MaterialDesignIconButton}"
                                    Command="{Binding SelectLanguageCommand}"
                                    Margin="8,0,0,0">
                                <materialDesign:PackIcon Kind="Translate"/>
                            </Button>
                        </Grid>

                        <!-- Document Options -->
                        <TextBlock Text="Document Options" Style="{DynamicResource MaterialDesignBody2TextBlock}" Margin="0,0,0,8"/>
                        <StackPanel Orientation="Horizontal" Margin="0,0,0,16">
                            <RadioButton Style="{DynamicResource MaterialDesignRadioButton}"
                                         Content="Individual Files"
                                         IsChecked="{Binding SelectedDocumentOption, Converter={StaticResource EnumToBooleanConverter}, ConverterParameter=Individual}"
                                         GroupName="DocumentOptions"/>
                            <RadioButton Style="{DynamicResource MaterialDesignRadioButton}"
                                         Content="Combined PDF"
                                         IsChecked="{Binding SelectedDocumentOption, Converter={StaticResource EnumToBooleanConverter}, ConverterParameter=Combined}"
                                         GroupName="DocumentOptions"
                                         Margin="16,0,0,0"/>
                        </StackPanel>

                        <StackPanel DataContext="{Binding DataContext, ElementName=LeftPanelCard}">
                            <!-- Output Path -->
                            <TextBlock Text="Output Path" Style="{DynamicResource MaterialDesignBody2TextBlock}" Margin="0,0,0,8"/>
                            <Grid Margin="0,0,0,16">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="Auto"/>
                                </Grid.ColumnDefinitions>
                                <TextBox Grid.Column="0" 
                                         Text="{Binding OutputSettingsViewModel.OutputPath, UpdateSourceTrigger=PropertyChanged}"
                                         materialDesign:HintAssist.Hint="Output Folder"
                                         IsReadOnly="True"
                                         AllowDrop="True"
                                         PreviewDragOver="OutputPath_PreviewDragOver"
                                         Drop="OutputPath_Drop"
                                         materialDesign:HintAssist.HelperText="{Binding OutputSettingsViewModel.OutputPathError}">
                                    <TextBox.Style>
                                        <Style TargetType="TextBox" BasedOn="{StaticResource MaterialDesignOutlinedTextBox}">
                                        <Style.Triggers>
                                            <DataTrigger Binding="{Binding OutputSettingsViewModel.IsOutputPathValid}" Value="False">
                                                <Setter Property="materialDesign:HintAssist.Foreground" Value="{DynamicResource MaterialDesignValidationErrorBrush}"/>
                                            </DataTrigger>
                                        </Style.Triggers>
                                    </Style>
                                    </TextBox.Style>
                                </TextBox>
                                <Button Grid.Column="1" 
                                        Style="{DynamicResource MaterialDesignIconButton}"
                                        Command="{Binding SelectOutputFolderCommand}"
                                        Margin="8,0,0,0">
                                    <materialDesign:PackIcon Kind="FolderOpen"/>
                                </Button>
                            </Grid>

                            <!-- Recent Folders -->
                            <ComboBox Style="{DynamicResource MaterialDesignOutlinedComboBox}"
                                      ItemsSource="{Binding OutputSettingsViewModel.RecentFolders}"
                                      SelectedItem="{Binding OutputSettingsViewModel.OutputPath}"
                                      materialDesign:HintAssist.Hint="Recent Folders"
                                      Margin="0,0,0,16"/>

                            <!-- Recent Files -->
                            <ComboBox Style="{DynamicResource MaterialDesignOutlinedComboBox}"
                                      ItemsSource="{Binding OutputSettingsViewModel.RecentFiles}"
                                      materialDesign:HintAssist.Hint="Recent Files"
                                      Margin="0,0,0,16"/>

                            <!-- Base File Name -->
                            <TextBlock Text="Base File Name" Style="{DynamicResource MaterialDesignBody2TextBlock}" Margin="0,0,0,8"/>
                            <TextBox 
                                     Text="{Binding OutputSettingsViewModel.BaseFileName, UpdateSourceTrigger=PropertyChanged}"
                                     materialDesign:HintAssist.Hint="Base file name (no extension)"
                                     materialDesign:HintAssist.HelperText="{Binding OutputSettingsViewModel.BaseFileNameError}"
                                     Margin="0,0,0,8">
                                <TextBox.Style>
                                    <Style TargetType="TextBox" BasedOn="{StaticResource MaterialDesignOutlinedTextBox}">
                                        <Style.Triggers>
                                            <DataTrigger Binding="{Binding OutputSettingsViewModel.IsBaseFileNameValid}" Value="False">
                                                <Setter Property="materialDesign:HintAssist.Foreground" Value="{DynamicResource MaterialDesignValidationErrorBrush}"/>
                                            </DataTrigger>
                                        </Style.Triggers>
                                    </Style>
                                </TextBox.Style>
                            </TextBox>
                            <TextBlock Text="{Binding OutputSettingsViewModel.FileNamePreview}" 
                                       Style="{DynamicResource MaterialDesignBody2TextBlock}" 
                                       Margin="0,0,0,16"/>

                            <!-- Scan Buttons -->
                            <StackPanel Orientation="Horizontal" HorizontalAlignment="Stretch">
                                <Button Style="{DynamicResource MaterialDesignRaisedButton}"
                                        Command="{Binding DataContext.ScanDocumentsCommand, ElementName=LeftPanelCard}"
                                        HorizontalAlignment="Stretch"
                                        HorizontalContentAlignment="Center">
                                    <StackPanel Orientation="Horizontal">
                                        <materialDesign:PackIcon Kind="Play" Margin="0,0,8,0"/>
                                        <TextBlock Text="Start Scan"/>
                                    </StackPanel>
                                </Button>
                            </StackPanel>
                            
                            <Button Style="{DynamicResource MaterialDesignOutlinedButton}"
                                    Command="{Binding CancelScanCommand}"
                                    IsEnabled="{Binding CanStopScan}"
                                    HorizontalAlignment="Stretch"
                                    Margin="0,8,0,0">
                                <StackPanel Orientation="Horizontal">
                                    <materialDesign:PackIcon Kind="Stop" Margin="0,0,8,0"/>
                                    <TextBlock Text="Stop Scan"/>
                                </StackPanel>
                            </Button>
                        </StackPanel>
                    </StackPanel>
                </ScrollViewer>
            </materialDesign:Card>

            <!-- Splitter -->
            <GridSplitter Grid.Column="1" HorizontalAlignment="Stretch" VerticalAlignment="Stretch" Width="8" Background="{DynamicResource MaterialDesignDivider}" ShowsPreview="True"/>

            <!-- Right Panel - Preview -->
            <materialDesign:Card Grid.Column="2" Padding="16" materialDesign:ElevationAssist.Elevation="Dp2" Background="#FAFAFA" DataContext="{Binding PreviewViewModel}">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>

                    <!-- Preview Header -->
                    <Grid Grid.Row="0" Margin="0,0,0,16">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>
                        <TextBlock Grid.Column="0" Text="Document Preview" Style="{DynamicResource MaterialDesignHeadline6TextBlock}"/>
                        <StackPanel Grid.Column="1" Orientation="Horizontal">
                            <Button Style="{DynamicResource MaterialDesignIconButton}"
                                    Command="{Binding DataContext.ClearPreviewCommand, ElementName=LeftPanelCard}"
                                    ToolTip="Clear Preview">
                                <materialDesign:PackIcon Kind="Delete"/>
                            </Button>
                            <Button Style="{DynamicResource MaterialDesignIconButton}"
                                    Command="{Binding DataContext.SavePreviewCommand, ElementName=LeftPanelCard}"
                                    ToolTip="Save Preview">
                                <materialDesign:PackIcon Kind="ContentSave"/>
                            </Button>
                        </StackPanel>
                    </Grid>

                    <!-- Preview Area -->
                    <Border Grid.Row="1"
                            BorderBrush="{DynamicResource MaterialDesignDivider}"
                            BorderThickness="1"
                            Background="#FFF"
                            CornerRadius="4"
                            MinHeight="300">
                        <Grid>
                            <Grid.Resources>
                                <BooleanToVisibilityConverter x:Key="BoolToVis"/>
                            </Grid.Resources>
                            <ScrollViewer HorizontalScrollBarVisibility="Auto" VerticalScrollBarVisibility="Auto"
                                          Visibility="{Binding HasPreviewImage, Converter={StaticResource BooleanToVisibilityConverter}}"
                                          MouseWheel="PreviewImage_MouseWheel"
                                          MouseMove="PreviewImage_MouseMove"
                                          MouseLeftButtonDown="PreviewImage_MouseLeftButtonDown"
                                          MouseLeftButtonUp="PreviewImage_MouseLeftButtonUp">
                                <Image Source="{Binding PreviewImage}"
                                       RenderOptions.BitmapScalingMode="HighQuality"
                                       VerticalAlignment="Center" HorizontalAlignment="Center">
                                    <Image.RenderTransform>
                                        <TransformGroup>
                                            <ScaleTransform ScaleX="{Binding Scale}" ScaleY="{Binding Scale}"/>
                                            <TranslateTransform X="{Binding OffsetX}" Y="{Binding OffsetY}"/>
                                        </TransformGroup>
                                    </Image.RenderTransform>
                                </Image>
                            </ScrollViewer>
                            <Viewbox Stretch="Uniform">
                                <Viewbox.Style>
                                    <Style TargetType="Viewbox">
                                        <Setter Property="Visibility" Value="Visible"/>
                                        <Style.Triggers>
                                            <DataTrigger Binding="{Binding HasPreviewImage}" Value="True">
                                                <Setter Property="Visibility" Value="Collapsed"/>
                                            </DataTrigger>
                                        </Style.Triggers>
                                    </Style>
                                </Viewbox.Style>
                                <StackPanel HorizontalAlignment="Center" VerticalAlignment="Center" Margin="32">
                                    <Image Source="pack://application:,,,/Scandalous;component/Scandalous-app-icon.ico" Width="64" Height="64" Margin="0,0,0,16"/>
                                    <TextBlock Text="No document scanned yet" Style="{DynamicResource MaterialDesignBody1TextBlock}" HorizontalAlignment="Center"/>
                                    <TextBlock Text="Start a scan to see a preview here." Style="{DynamicResource MaterialDesignBody2TextBlock}" HorizontalAlignment="Center" Opacity="0.7"/>
                                </StackPanel>
                            </Viewbox>
                        </Grid>
                    </Border>

                    <!-- Status -->
                    <StackPanel Grid.Row="2" Orientation="Horizontal" Margin="0,16,0,0" DataContext="{Binding DataContext, ElementName=LeftPanelCard}">
                        <materialDesign:PackIcon Kind="Information" Width="16" Height="16" VerticalAlignment="Center" Margin="0,0,8,0"/>
                        <TextBlock Text="{Binding StatusMessage}" Style="{DynamicResource MaterialDesignBody2TextBlock}" VerticalAlignment="Center"/>
                    </StackPanel>
                </Grid>
            </materialDesign:Card>
        </Grid>

        <!-- Progress Bar -->
        <Grid Grid.Row="1" Margin="16,0,16,16" VerticalAlignment="Bottom" Visibility="{Binding IsLoading, Converter={StaticResource BooleanToVisibilityConverter}}">
            <StackPanel>
                <Grid Margin="0,0,0,8">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>
                    <TextBlock Grid.Column="0" Text="{Binding ScanStatusMessage}" Style="{DynamicResource MaterialDesignBody1TextBlock}"/>
                    <TextBlock Grid.Column="1" Text="{Binding ScanProgress, StringFormat='{}{0}%'}" Style="{DynamicResource MaterialDesignBody2TextBlock}"/>
                </Grid>
                <ProgressBar Style="{DynamicResource MaterialDesignLinearProgressBar}"
                                Value="{Binding ScanProgress}"
                                Maximum="100"/>
            </StackPanel>
        </Grid>

        <!-- Snackbar for notifications -->
        <materialDesign:Snackbar x:Name="MainSnackbar" MessageQueue="{materialDesign:MessageQueue}" Grid.Row="3"/>
    </Grid>
</Window>